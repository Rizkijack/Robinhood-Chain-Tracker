# Environment Variables Template
# Copy this file to .env.local and fill in the values

# Privy App ID
# Get from Privy dashboard: https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here

# Reown Project ID  
# Get from Reown dashboard: https://reown.com/dashboard
NEXT_PUBLIC_REOWN_PROJECT_ID=your_reown_project_id_here

# WalletConnect Project ID (optional, for WalletConnect integration)
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Alchemy API Key (optional, for RPC endpoints)
# NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_api_key_here

# CoinGecko API key (optional but recommended for reliable real-time price/mcap enrichment)
# Get from CoinGecko dashboard: https://www.coingecko.com/api/pricing
# Demo keys start with "CG-" and use the x-cg-demo-api-key header automatically.
COINGECKO_API_KEY=

# Default Chain ID (optional)
# NEXT_PUBLIC_DEFAULT_CHAIN_ID=8453

# Database URL (optional, for persistent storage)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname